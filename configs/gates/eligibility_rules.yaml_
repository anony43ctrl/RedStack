hard_blocks:
  - code: pure_research_no_production
    description: "Research-aligned profile with no production-company tenure."
  - code: langchain_openai_only_recent
    description: "Recent framework-name claims without corroborated depth."
  - code: no_production_code_18m
    description: "No production-company role within the recency window."
  - code: consulting_firms_only_career
    description: "Entire career at consulting firms; no product-side delivery."
  - code: primary_cv_speech_robotics_no_nlp
    description: "Primary expertise in an adjacent vision/speech/robotics domain."
  - code: closed_source_5y_no_validation
    description: "Long closed-source tenure with no externally validated competency."
soft_penalties:
  - code: title_chaser_sub_18m_hops
    description: "High hop rate: many sub-18-month tenures."
    penalty: 0.15
  - code: notice_over_30
    description: "Notice period exceeds 30 days."
    penalty: 0.10
  - code: outside_india_no_sponsor
    description: "Located outside India without a sponsorship path."
    penalty: 0.15
  - code: outside_experience_band
    description: "Derived experience outside the JD's target band."
    penalty: 0.10